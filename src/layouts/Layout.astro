---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Alex Clark — eCommerce Leader & CRO Specialist',
  description = 'eCommerce leader crafting measurable digital experiences. Portfolio showcasing work at Fender, SOREL, Dr. Martens, and beyond.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
