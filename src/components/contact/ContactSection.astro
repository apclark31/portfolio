---
/* Contact section */
---

<section class="contact" id="contact">
  <div class="container">
    <div class="contact-grid">
      <!-- Contact Info -->
      <div class="contact-info">
        <h2 class="contact-title font-headline">Get in Touch</h2>
        <p class="contact-desc font-body">
          Whether you have an opportunity, a project, or just want to connect,
          I'm always open to a conversation.
        </p>

        <div class="contact-details">
          <div class="contact-detail">
            <div class="contact-icon-circle">
              <span class="material-symbols-outlined">public</span>
            </div>
            <div>
              <p class="contact-detail-label font-label">Socials</p>
              <div class="contact-socials">
                <a href="https://www.linkedin.com/in/alex-p-clark/" target="_blank" rel="noopener noreferrer" class="contact-social">LinkedIn</a>
                <a href="https://github.com/apclark31" target="_blank" rel="noopener noreferrer" class="contact-social">GitHub</a>
              </div>
            </div>
          </div>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="contact-form-panel">
        <form class="contact-form" id="contact-form" action="https://api.web3forms.com/submit" method="POST">
          <input type="hidden" name="access_key" value="b4d98f63-964a-43ca-9f00-da883ed5a560" />
          <input type="hidden" name="subject" value="New contact from alexpnw.com" />
          <input type="checkbox" name="botcheck" class="visually-hidden" style="display:none" />

          <div class="form-field">
            <label for="name" class="form-label font-label">Full Name</label>
            <input type="text" id="name" name="name" required class="form-input" placeholder="John Doe" />
          </div>

          <div class="form-field">
            <label for="email" class="form-label font-label">Email Address</label>
            <input type="email" id="email" name="email" required class="form-input" placeholder="john@example.com" />
          </div>

          <div class="form-field">
            <label for="message" class="form-label font-label">Your Message</label>
            <textarea id="message" name="message" rows="4" required class="form-input form-textarea" placeholder="How can we help each other?"></textarea>
          </div>

          <button type="submit" class="form-submit signature-gradient" id="contact-submit">
            Send Message
            <span class="material-symbols-outlined">send</span>
          </button>
        </form>
        <div class="form-success" id="form-success">
          <span class="material-symbols-outlined form-success-icon">check_circle</span>
          <p class="form-success-title font-headline">Message sent!</p>
          <p class="form-success-desc font-body">Thanks for reaching out. I'll get back to you soon.</p>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    padding-block: var(--space-12);
  }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background-color: var(--color-surface-container-low);
  }

  @media (min-width: 1024px) {
    .contact-grid {
      grid-template-columns: 1fr 1fr;
    }
  }

  /* Info panel */
  .contact-info {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    padding: var(--space-12);
  }

  @media (min-width: 1024px) {
    .contact-info {
      padding: var(--space-20);
    }
  }

  .contact-title {
    font-size: clamp(2rem, 4vw, var(--text-display-md));
    font-weight: 800;
    letter-spacing: var(--tracking-tighter);
    margin-bottom: var(--space-8);
  }

  .contact-desc {
    font-size: var(--text-title-md);
    color: rgba(192, 255, 243, 0.7);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-12);
    max-width: 28rem;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .contact-detail {
    display: flex;
    align-items: flex-start;
    gap: var(--space-6);
  }

  .contact-icon-circle {
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-full);
    background-color: rgba(106, 242, 222, 0.2);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-icon-circle .material-symbols-outlined {
    color: var(--color-primary-container);
    font-size: 1.25rem;
  }

  .contact-detail-label {
    font-size: var(--text-body-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: var(--color-primary-container);
    margin-bottom: var(--space-1);
  }

  .contact-socials {
    display: flex;
    gap: var(--space-6);
    margin-top: var(--space-2);
  }

  .contact-social {
    font-weight: 700;
    color: var(--color-on-primary);
    transition: color var(--duration-normal) var(--ease-default);
  }

  .contact-social:hover {
    color: var(--color-primary-container);
  }

  /* Form panel */
  .contact-form-panel {
    background-color: var(--color-surface-container-lowest);
    padding: var(--space-12);
  }

  @media (min-width: 1024px) {
    .contact-form-panel {
      padding: var(--space-20);
    }
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .form-label {
    font-size: var(--text-body-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: var(--color-outline);
  }

  .form-input {
    font-family: var(--font-body);
    font-size: var(--text-body-md);
    padding: var(--space-4);
    border: none;
    border-radius: var(--radius-lg);
    background-color: var(--color-surface-container-low);
    color: var(--color-on-surface);
    transition: box-shadow var(--duration-normal) var(--ease-default);
    outline: none;
  }

  .form-input:focus {
    box-shadow: 0 0 0 2px var(--color-primary);
  }

  .form-input::placeholder {
    color: var(--color-outline-variant);
  }

  .form-textarea {
    resize: vertical;
    min-height: 100px;
  }

  .form-submit {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-3);
    padding: var(--space-5) var(--space-8);
    border: none;
    border-radius: var(--radius-full);
    font-family: var(--font-body);
    font-weight: 700;
    font-size: var(--text-body-lg);
    color: var(--color-on-primary);
    cursor: pointer;
    transition: opacity var(--duration-normal) var(--ease-default);
  }

  .form-submit:hover {
    opacity: 0.9;
  }

  .form-submit .material-symbols-outlined {
    font-size: 1.25rem;
  }

  /* Success state */
  .form-success {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    gap: var(--space-4);
    padding: var(--space-12);
  }

  .form-success.visible {
    display: flex;
  }

  .form-success-icon {
    font-size: 3rem;
    color: var(--color-primary);
  }

  .form-success-title {
    font-size: var(--text-headline-md);
    font-weight: 700;
    color: var(--color-on-surface);
  }

  .form-success-desc {
    font-size: var(--text-body-md);
    color: var(--color-on-surface-variant);
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success')!;
  const submitBtn = document.getElementById('contact-submit')!;

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.textContent = 'Sending...';

    try {
      const response = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form),
      });

      if (response.ok) {
        form.style.display = 'none';
        success.classList.add('visible');
      } else {
        submitBtn.textContent = 'Something went wrong. Try again.';
      }
    } catch {
      submitBtn.textContent = 'Something went wrong. Try again.';
    }
  });
</script>
