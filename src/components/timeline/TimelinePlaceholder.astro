---
import TagPill from '../shared/TagPill.astro';

/* Static timeline placeholder — will be replaced by GSAP React island in Phase 4 */
const entries = [
  {
    dateRange: '2024 — Present',
    role: 'Senior eCommerce Manager',
    company: 'Fender Musical Instruments',
    description: 'Returned to lead eCommerce growth strategy and site optimization for one of the world\'s most iconic music brands.',
    tags: ['eCommerce', 'CRO', 'Strategy'],
    side: 'right' as const,
    isCurrent: true,
    image: 'https://images.unsplash.com/photo-1511379938547-c1f69419868d?w=600&h=450&fit=crop',
  },
  {
    dateRange: '2024',
    role: 'Manager, Site Optimization',
    company: 'SOREL',
    description: 'Led site optimization and A/B testing initiatives, driving measurable conversion improvements across the DTC experience.',
    tags: ['A/B Testing', 'CRO', 'Analytics'],
    side: 'left' as const,
    isCurrent: false,
    image: 'https://images.unsplash.com/photo-1460925895917-afdab827c52f?w=600&h=450&fit=crop',
    caseStudy: true,
  },
  {
    dateRange: '2021 — 2024',
    role: 'eCommerce & Optimization Manager, Growth',
    company: 'Fender Musical Instruments',
    description: 'Managed eCommerce optimization, growth strategies, and conversion rate initiatives across the global digital storefront.',
    tags: ['Growth', 'eCommerce', 'Optimization'],
    side: 'right' as const,
    isCurrent: false,
    image: 'https://images.unsplash.com/photo-1551288049-bebda4e38f71?w=600&h=450&fit=crop',
  },
  {
    dateRange: '2016 — 2021',
    role: 'Sr. Manager, eCommerce Operations (Americas)',
    company: 'Dr. Martens — Airwair International',
    description: 'Progressive career from Retail IT Analyst to Senior Manager. Built and scaled the Americas eCommerce operation across multiple roles and promotions.',
    tags: ['eCommerce Ops', 'Team Leadership', 'DTC'],
    side: 'left' as const,
    isCurrent: false,
    image: 'https://images.unsplash.com/photo-1556742049-0cfed4f6a45d?w=600&h=450&fit=crop',
  },
  {
    dateRange: '2013 — 2016',
    role: 'IT Specialist',
    company: 'Made In Oregon',
    description: 'Administered network and hardware infrastructure for multiple retail locations, corporate office, and web department.',
    tags: ['IT Infrastructure', 'Retail Tech'],
    side: 'right' as const,
    isCurrent: false,
    image: 'https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=600&h=450&fit=crop',
  },
];
---

<div class="timeline-entries">
  <!-- Center line -->
  <div class="timeline-line"></div>

  {entries.map((entry, i) => (
    <div class={`timeline-entry timeline-entry--${entry.side}`}>
      <div class="timeline-entry-content">
        <div class={`timeline-date-badge ${entry.isCurrent ? 'timeline-date-badge--current' : ''}`}>
          {entry.dateRange}
        </div>
        <h3 class="timeline-entry-role font-headline">{entry.role}</h3>
        <p class="timeline-entry-company">{entry.company}</p>
        <p class="timeline-entry-desc font-body">{entry.description}</p>
        <div class="timeline-entry-tags">
          {entry.tags.map((tag) => (
            <TagPill>{tag}</TagPill>
          ))}
        </div>
        {entry.caseStudy && (
          <a href="#" class="timeline-case-study-link">
            View Case Study <span class="material-symbols-outlined">arrow_outward</span>
          </a>
        )}
      </div>

      <div class="timeline-entry-image-wrap">
        <div class="timeline-entry-image-glow"></div>
        <div class="timeline-entry-image">
          <img src={entry.image} alt={`${entry.company} work sample`} loading="lazy" />
        </div>
        <!-- Milestone marker -->
        <div class="timeline-marker">
          <div class={`timeline-marker-dot ${entry.isCurrent ? 'timeline-marker-dot--pulse' : ''}`}></div>
        </div>
      </div>
    </div>
  ))}
</div>

<style>
  .timeline-entries {
    position: relative;
    display: flex;
    flex-direction: column;
    gap: var(--space-32);
  }

  /* Center line */
  .timeline-line {
    display: none;
    position: absolute;
    left: 50%;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, rgba(0, 103, 93, 0.4), rgba(0, 103, 93, 0.1), transparent);
    transform: translateX(-50%);
  }

  @media (min-width: 768px) {
    .timeline-line {
      display: block;
    }
  }

  /* Entry layout */
  .timeline-entry {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  @media (min-width: 768px) {
    .timeline-entry {
      grid-template-columns: 1fr 1fr;
    }

    .timeline-entry--right .timeline-entry-content {
      order: 1;
      text-align: right;
    }
    .timeline-entry--right .timeline-entry-image-wrap {
      order: 2;
    }
    .timeline-entry--right .timeline-entry-tags {
      justify-content: flex-end;
    }

    .timeline-entry--left .timeline-entry-content {
      order: 2;
    }
    .timeline-entry--left .timeline-entry-image-wrap {
      order: 1;
    }
  }

  .timeline-entry-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .timeline-date-badge {
    display: inline-block;
    align-self: flex-start;
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius-full);
    background-color: var(--color-surface-container-high);
    color: var(--color-on-surface-variant);
    font-family: var(--font-headline);
    font-size: var(--text-body-sm);
    font-weight: 700;
  }

  .timeline-date-badge--current {
    background-color: var(--color-primary-container);
    color: var(--color-on-primary-container);
  }

  @media (min-width: 768px) {
    .timeline-entry--right .timeline-date-badge {
      align-self: flex-end;
    }
  }

  .timeline-entry-role {
    font-size: var(--text-headline-md);
    font-weight: 700;
    color: var(--color-on-surface);
  }

  .timeline-entry-company {
    font-size: var(--text-title-md);
    font-weight: 600;
    color: var(--color-primary);
  }

  .timeline-entry-desc {
    font-size: var(--text-body-md);
    color: var(--color-on-surface-variant);
    line-height: var(--leading-relaxed);
  }

  .timeline-entry-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .timeline-case-study-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-1);
    color: var(--color-primary);
    font-weight: 700;
    font-size: var(--text-body-sm);
    transition: gap var(--duration-normal) var(--ease-default);
  }

  .timeline-case-study-link:hover {
    gap: var(--space-2);
  }

  .timeline-case-study-link .material-symbols-outlined {
    font-size: 0.875rem;
  }

  /* Image side */
  .timeline-entry-image-wrap {
    position: relative;
  }

  .timeline-entry-image-glow {
    position: absolute;
    inset: -1rem;
    background-color: rgba(0, 103, 93, 0.05);
    border-radius: var(--radius-3xl);
    filter: blur(30px);
    transition: background-color var(--duration-normal) var(--ease-default);
  }

  .timeline-entry:hover .timeline-entry-image-glow {
    background-color: rgba(0, 103, 93, 0.1);
  }

  .timeline-entry-image {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-2xl);
    aspect-ratio: 4 / 3;
    background-color: var(--color-surface-container-low);
    box-shadow: var(--shadow-xl);
  }

  .timeline-entry-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slower) var(--ease-default);
  }

  .timeline-entry:hover .timeline-entry-image img {
    transform: scale(1.05);
  }

  /* Milestone marker */
  .timeline-marker {
    display: none;
    position: absolute;
    top: 50%;
    width: 3rem;
    height: 3rem;
    background-color: var(--color-surface);
    border: 4px solid var(--color-primary);
    border-radius: var(--radius-full);
    z-index: 10;
    transform: translateY(-50%);
    align-items: center;
    justify-content: center;
    box-shadow: var(--shadow-lg);
  }

  @media (min-width: 768px) {
    .timeline-marker {
      display: flex;
    }

    .timeline-entry--right .timeline-marker {
      left: calc(-1 * var(--space-6));
      transform: translate(-50%, -50%);
    }

    .timeline-entry--left .timeline-marker {
      right: calc(-1 * var(--space-6));
      transform: translate(50%, -50%);
    }
  }

  .timeline-marker-dot {
    width: 0.75rem;
    height: 0.75rem;
    background-color: var(--color-primary);
    border-radius: var(--radius-full);
  }

  .timeline-marker-dot--pulse {
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }
</style>
