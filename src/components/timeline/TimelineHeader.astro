---
import GradientButton from '../shared/GradientButton.astro';
import SecondaryButton from '../shared/SecondaryButton.astro';
---

<header class="timeline-header container">
  <div class="timeline-header-inner">
    <div class="timeline-header-text">
      <span class="section-label">Career</span>
      <h2 class="timeline-header-title font-headline">Experience</h2>
      <p class="timeline-header-desc font-body">
        A chronological exhibition of digital craftsmanship, conversion
        strategies, and interface architecture.
      </p>
    </div>

    <div class="timeline-header-actions">
      <SecondaryButton href="#" icon="description">Resume</SecondaryButton>
      <GradientButton href="https://www.linkedin.com/in/alex-p-clark/" icon="link">
        LinkedIn
      </GradientButton>
    </div>
  </div>
</header>

<style>
  .timeline-header {
    margin-bottom: var(--space-24);
  }

  .timeline-header-inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .timeline-header-inner {
      flex-direction: row;
      align-items: flex-end;
      justify-content: space-between;
    }
  }

  .timeline-header-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 40rem;
  }

  .timeline-header-title {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 800;
    letter-spacing: var(--tracking-tighter);
    color: var(--color-on-surface);
  }

  .timeline-header-desc {
    font-size: var(--text-title-md);
    color: var(--color-on-surface-variant);
    line-height: var(--leading-relaxed);
  }

  .timeline-header-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
  }
</style>
