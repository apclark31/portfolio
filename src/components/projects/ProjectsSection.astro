---
interface Project {
  title: string;
  description: string;
  type: 'main' | 'secondary' | 'hobby';
  tags?: string[];
  image?: string;
  link?: string;
  url?: string;
  github?: string;
  badge?: string;
  hashtags?: string[];
}

interface Props {
  projects: Project[];
}

const { projects } = Astro.props;

const mainProject = projects.find(p => p.type === 'main');
const secondaryProject = projects.find(p => p.type === 'secondary');
const hobbyProject = projects.find(p => p.type === 'hobby');
---

<section class="projects" id="projects">
  <div class="container">
    <!-- Header -->
    <header class="projects-header">
      <span class="section-label">Projects</span>
      <h1 class="projects-title font-headline">Tools &amp; Side Projects</h1>
      <p class="projects-desc font-body">
        Applications and tools I've built — from analytics dashboards to
        browser extensions to music theory visualizers. Published on GitHub
        with documentation.
      </p>
    </header>

    <!-- Projects Bento Grid (12 col) -->
    <div class="projects-bento">
      {mainProject && (
        <div class="project-card project-main">
          <div class="project-image-wrap">
            <img
              src={mainProject.image}
              alt={`${mainProject.title} interface`}
              loading="lazy"
            />
            {mainProject.tags && mainProject.tags.length > 0 && (
              <div class="project-image-tags">
                {mainProject.tags.map((tag) => (
                  <span class="project-image-tag">{tag}</span>
                ))}
              </div>
            )}
          </div>
          <div class="project-body">
            <h3 class="project-title font-headline">{mainProject.title}</h3>
            <p class="project-desc font-body">{mainProject.description}</p>
            <div class="project-links">
              {mainProject.github && (
                <a href={mainProject.github} target="_blank" rel="noopener noreferrer" class="project-link">
                  GitHub
                  <span class="material-symbols-outlined">open_in_new</span>
                </a>
              )}
              {mainProject.url && (
                <a href={mainProject.url} target="_blank" rel="noopener noreferrer" class="project-link">
                  Live Demo
                  <span class="material-symbols-outlined">arrow_forward</span>
                </a>
              )}
            </div>
          </div>
        </div>
      )}

      {secondaryProject && (
        <div class="project-card project-secondary">
          <div class="project-body project-body-grow">
            {secondaryProject.badge && <span class="project-badge">{secondaryProject.badge}</span>}
            <h3 class="project-title font-headline">{secondaryProject.title}</h3>
            <p class="project-desc font-body">{secondaryProject.description}</p>
            {secondaryProject.hashtags && secondaryProject.hashtags.length > 0 && (
              <div class="project-hashtags">
                {secondaryProject.hashtags.map((tag) => (
                  <span>{tag}</span>
                ))}
              </div>
            )}
          </div>
          <div class="project-secondary-cta">
            <a href={secondaryProject.github || secondaryProject.url || '#'} target="_blank" rel="noopener noreferrer" class="project-cta-btn signature-gradient">
              View on GitHub
              <span class="material-symbols-outlined">open_in_new</span>
            </a>
          </div>
        </div>
      )}

      {hobbyProject && (
        <div class="project-card project-hobby">
          <div class="project-hobby-inner">
            <div class="project-hobby-image">
              <img
                src={hobbyProject.image}
                alt={`${hobbyProject.title} preview`}
                loading="lazy"
              />
            </div>
            <div class="project-hobby-content">
              <h3 class="project-title font-headline">{hobbyProject.title}</h3>
              <p class="project-desc font-body">{hobbyProject.description}</p>
              <a href={hobbyProject.github || hobbyProject.url || '#'} target="_blank" rel="noopener noreferrer" class="project-link">
                View on GitHub
                <span class="material-symbols-outlined">open_in_new</span>
              </a>
            </div>
          </div>
        </div>
      )}

      <!-- CTA (7 cols) -->
      <div class="project-card project-cta">
        <div class="project-cta-glow project-cta-glow-tl"></div>
        <div class="project-cta-glow project-cta-glow-br"></div>
        <span class="project-cta-label font-label">Open to Opportunities</span>
        <h2 class="project-cta-title font-headline">
          Looking for an eCommerce leader who can build and optimize?
        </h2>
        <a href="/contact" class="project-cta-button">Get in Touch</a>
      </div>
    </div>
  </div>
</section>

<style>
  .projects {
    padding-block: var(--space-24);
  }

  .projects-header {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-20);
    max-width: 48rem;
  }

  .projects-title {
    font-size: clamp(2.5rem, 6vw, var(--text-display-lg));
    font-weight: 800;
    letter-spacing: var(--tracking-tighter);
    color: var(--color-on-surface);
    line-height: var(--leading-tight);
  }

  .projects-desc {
    font-size: var(--text-title-md);
    color: var(--color-on-surface-variant);
    line-height: var(--leading-relaxed);
    max-width: 40rem;
  }

  /* Bento grid */
  .projects-bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
  }

  @media (min-width: 768px) {
    .projects-bento {
      grid-template-columns: repeat(12, 1fr);
    }
  }

  .project-card {
    border-radius: var(--radius-3xl);
    overflow: hidden;
  }

  /* Main project (8 cols) */
  .project-main {
    background-color: var(--color-surface-container-low);
  }

  @media (min-width: 768px) {
    .project-main { grid-column: span 8; }
  }

  .project-image-wrap {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background-color: var(--color-surface-container);
  }

  .project-image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slower) var(--ease-default);
  }

  .project-main:hover .project-image-wrap img {
    transform: scale(1.05);
  }

  .project-image-tags {
    position: absolute;
    top: var(--space-6);
    left: var(--space-6);
    display: flex;
    gap: var(--space-2);
  }

  .project-image-tag {
    padding: var(--space-1) var(--space-3);
    background: rgba(255, 255, 255, 0.9);
    backdrop-filter: blur(8px);
    border-radius: var(--radius-full);
    font-size: var(--text-label-md);
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
  }

  .project-body {
    padding: var(--space-10);
  }

  .project-title {
    font-size: var(--text-headline-md);
    font-weight: 700;
    margin-bottom: var(--space-4);
    color: var(--color-on-surface);
  }

  .project-desc {
    font-size: var(--text-body-md);
    color: var(--color-on-surface-variant);
    line-height: var(--leading-relaxed);
    margin-bottom: var(--space-8);
    max-width: 36rem;
  }

  .project-links {
    display: flex;
    gap: var(--space-6);
  }

  .project-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    color: var(--color-primary);
    font-weight: 700;
    font-size: var(--text-body-md);
  }

  .project-link .material-symbols-outlined {
    font-size: 1rem;
    transition: transform var(--duration-normal) var(--ease-default);
  }

  .project-link:hover .material-symbols-outlined {
    transform: translateX(4px);
  }

  /* Secondary project (4 cols) */
  .project-secondary {
    background-color: var(--color-surface-container-highest);
    display: flex;
    flex-direction: column;
  }

  @media (min-width: 768px) {
    .project-secondary { grid-column: span 4; }
  }

  .project-body-grow {
    flex: 1;
  }

  .project-badge {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    background-color: rgba(0, 103, 93, 0.1);
    border-radius: var(--radius-full);
    font-size: var(--text-label-md);
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    margin-bottom: var(--space-6);
  }

  .project-secondary .project-title {
    font-size: var(--text-headline-sm);
  }

  .project-hashtags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    font-size: var(--text-label-md);
    font-weight: 500;
    color: var(--color-on-surface-variant);
  }

  .project-secondary-cta {
    padding: 0 var(--space-10) var(--space-10);
  }

  .project-cta-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-2);
    padding: var(--space-4);
    border: none;
    border-radius: var(--radius-full);
    font-family: var(--font-body);
    font-weight: 700;
    color: var(--color-on-primary);
    cursor: pointer;
    transition: opacity var(--duration-normal) var(--ease-default);
  }

  .project-cta-btn:hover {
    opacity: 0.9;
  }

  .project-cta-btn .material-symbols-outlined {
    font-size: 1rem;
  }

  /* Hobby project (5 cols, horizontal) */
  .project-hobby {
    background-color: var(--color-surface-container);
  }

  @media (min-width: 768px) {
    .project-hobby { grid-column: span 5; }
  }

  .project-hobby-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  @media (min-width: 768px) {
    .project-hobby-inner {
      flex-direction: row;
    }
  }

  .project-hobby-image {
    overflow: hidden;
    flex-shrink: 0;
  }

  @media (min-width: 768px) {
    .project-hobby-image {
      width: 50%;
    }
  }

  .project-hobby-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--duration-slower) var(--ease-default);
  }

  .project-hobby:hover .project-hobby-image img {
    transform: scale(1.1);
  }

  .project-hobby-content {
    padding: var(--space-10);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .project-hobby-content {
      width: 50%;
    }
  }

  .project-hobby .project-title {
    font-size: var(--text-headline-sm);
  }

  .project-hobby .project-link {
    margin-top: auto;
  }

  .project-hobby .project-link .material-symbols-outlined {
    transition: transform var(--duration-normal) var(--ease-default);
  }

  .project-hobby:hover .project-link .material-symbols-outlined {
    transform: rotate(45deg);
  }

  /* CTA card (7 cols) */
  .project-cta {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    padding: var(--space-12);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .project-cta { grid-column: span 7; }
  }

  .project-cta-glow {
    position: absolute;
    border-radius: var(--radius-full);
    opacity: 0.1;
    pointer-events: none;
  }

  .project-cta-glow-tl {
    top: 0;
    left: 0;
    width: 16rem;
    height: 16rem;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-container));
    filter: blur(60px);
    transform: translate(-50%, -50%);
  }

  .project-cta-glow-br {
    bottom: 0;
    right: 0;
    width: 24rem;
    height: 24rem;
    background: linear-gradient(135deg, var(--color-primary), var(--color-primary-container));
    filter: blur(60px);
    transform: translate(50%, 50%);
  }

  .project-cta-label {
    font-size: var(--text-label-md);
    text-transform: uppercase;
    letter-spacing: 0.3em;
    opacity: 0.8;
    margin-bottom: var(--space-6);
  }

  .project-cta-title {
    font-size: var(--text-headline-lg);
    font-weight: 700;
    margin-bottom: var(--space-8);
    max-width: 28rem;
    line-height: var(--leading-tight);
  }

  .project-cta-button {
    display: inline-block;
    padding: var(--space-4) var(--space-10);
    background-color: var(--color-surface-container-lowest);
    color: var(--color-primary);
    border-radius: var(--radius-full);
    font-weight: 700;
    font-size: var(--text-body-lg);
    transition: background-color var(--duration-normal) var(--ease-default);
    position: relative;
    z-index: 1;
  }

  .project-cta-button:hover {
    background-color: var(--color-on-primary);
  }
</style>
