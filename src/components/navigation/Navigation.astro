---
interface Props {
  activePath?: string;
}

const { activePath = '/' } = Astro.props;

const navLinks = [
  { href: '/#about', label: 'About' },
  { href: '/experience', label: 'Experience' },
  { href: '/projects', label: 'Projects' },
];
---

<nav class="nav glass" id="main-nav">
  <div class="nav-inner container">
    <a href="/" class="nav-logo font-headline">Alex Clark <svg class="nav-tree" viewBox="0 0 60 80" fill="currentColor" aria-hidden="true"><path d="M30 0 L24 12 L28 12 L18 28 L24 28 L12 46 L20 46 L6 66 L22 66 L22 80 L38 80 L38 66 L54 66 L40 46 L48 46 L36 28 L42 28 L32 12 L36 12 Z"/></svg></a>

    <div class="nav-links" id="nav-links">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class={`nav-link ${activePath === link.href ? 'active' : ''}`}
        >
          {link.label}
        </a>
      ))}
      <a href="/#contact" class="nav-cta nav-cta-mobile">Contact</a>
    </div>

    <a href="/#contact" class={`nav-cta nav-cta-desktop ${activePath === '/contact' ? 'nav-cta--active' : ''}`}>Contact</a>

    <button class="nav-hamburger" id="nav-hamburger" aria-label="Toggle menu" aria-expanded="false">
      <span class="nav-hamburger-line"></span>
      <span class="nav-hamburger-line"></span>
      <span class="nav-hamburger-line"></span>
    </button>
  </div>
</nav>

<style>
  .nav {
    position: fixed;
    top: 0;
    width: 100%;
    z-index: 50;
    box-shadow: var(--shadow-sm);
  }

  .nav-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--space-4);
  }

  .nav-logo {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: var(--tracking-tighter);
    color: var(--color-on-surface);
  }

  .nav-tree {
    width: 0.65em;
    height: 0.8em;
    color: var(--color-primary);
  }

  .nav-links {
    display: none;
    font-family: var(--font-headline);
    letter-spacing: var(--tracking-tight);
  }

  .nav-link {
    color: var(--color-on-surface-variant);
    font-size: var(--text-body-md);
    transition: color var(--duration-normal) var(--ease-default);
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--color-primary);
  }

  .nav-link.active {
    font-weight: 600;
    border-bottom: 2px solid var(--color-primary);
    padding-bottom: var(--space-1);
  }

  .nav-cta {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    padding: var(--space-2) var(--space-6);
    border-radius: var(--radius-full);
    font-weight: 700;
    font-size: var(--text-body-sm);
    transition: opacity var(--duration-normal) var(--ease-default),
                transform var(--duration-fast) var(--ease-default);
    text-decoration: none;
    text-align: center;
  }

  .nav-cta:hover {
    opacity: 0.85;
  }

  .nav-cta:active {
    transform: scale(0.95);
  }

  /* Desktop CTA hidden on mobile, mobile CTA hidden on desktop */
  .nav-cta-desktop {
    display: none;
  }

  .nav-cta-mobile {
    display: none;
  }

  /* Hamburger */
  .nav-hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 2.5rem;
    height: 2.5rem;
    padding: var(--space-2);
    background: none;
    border: none;
    cursor: pointer;
  }

  .nav-hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background-color: var(--color-on-surface);
    border-radius: 1px;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .nav-hamburger[aria-expanded="true"] .nav-hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }

  .nav-hamburger[aria-expanded="true"] .nav-hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .nav-hamburger[aria-expanded="true"] .nav-hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile menu open */
  .nav-links.open {
    display: flex;
    flex-direction: column;
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: rgba(255, 255, 255, 0.95);
    backdrop-filter: blur(20px);
    padding: var(--space-6) var(--space-8) var(--space-8);
    gap: var(--space-4);
    box-shadow: var(--shadow-md);
  }

  .nav-links.open .nav-cta-mobile {
    display: block;
    margin-top: var(--space-2);
  }

  /* Desktop */
  @media (min-width: 768px) {
    .nav-hamburger {
      display: none;
    }

    .nav-links {
      display: flex;
      gap: var(--space-8);
      align-items: center;
      position: static;
      background: none;
      backdrop-filter: none;
      padding: 0;
      box-shadow: none;
      flex-direction: row;
    }

    .nav-cta-desktop {
      display: inline-block;
    }

    .nav-cta-mobile {
      display: none !important;
    }
  }
</style>

<script>
  const hamburger = document.getElementById('nav-hamburger')!;
  const links = document.getElementById('nav-links')!;

  hamburger.addEventListener('click', () => {
    const expanded = hamburger.getAttribute('aria-expanded') === 'true';
    hamburger.setAttribute('aria-expanded', String(!expanded));
    links.classList.toggle('open');
  });

  // Close menu when a link is clicked
  links.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger.setAttribute('aria-expanded', 'false');
      links.classList.remove('open');
    });
  });
</script>
