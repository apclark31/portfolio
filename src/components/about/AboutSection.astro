---
/* About section — matches about_contact_me mockup bento layout */
---

<section class="about" id="about">
  <div class="container">
    <!-- About Hero -->
    <div class="about-hero">
      <div class="about-hero-text">
        <span class="section-label">The Human Behind The Code</span>
        <h1 class="about-title font-headline">
          Curating Digital Experiences with <span class="about-title-accent">Intentionality.</span>
        </h1>
        <p class="about-desc font-body">
          I bridge the gap between complex engineering and elegant human
          experiences. My approach isn't just about building — it's about
          selecting the right pieces to tell a cohesive story.
        </p>
      </div>

      <div class="about-hero-portrait">
        <img
          src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=500&h=500&fit=crop&crop=face"
          alt="Alex Clark"
          loading="lazy"
        />
      </div>
    </div>

    <!-- About Bento (6-col grid matching mockup) -->
    <div class="about-bento">
      <!-- Precision Workflow (spans 3) -->
      <div class="about-card about-card-workflow">
        <div>
          <span class="material-symbols-outlined about-card-icon">architecture</span>
          <h3 class="about-card-title font-headline">Precision Workflow</h3>
          <p class="about-card-desc font-body">
            My process begins with deep empathy and ends with pixel-perfect execution.
            I utilize a modular architecture approach, ensuring that every design system
            component is reusable, accessible, and performant.
          </p>
        </div>
        <div class="workflow-tags">
          <span class="workflow-tag">Research</span>
          <span class="workflow-tag">System Design</span>
          <span class="workflow-tag">Refinement</span>
        </div>
      </div>

      <!-- Fret Atlas Hobby (spans 3) -->
      <div class="about-card about-card-hobby">
        <div class="about-card-hobby-inner">
          <span class="material-symbols-outlined about-hobby-icon">music_note</span>
          <h3 class="about-card-title font-headline about-hobby-title">The Fret Atlas</h3>
          <p class="about-card-desc about-hobby-desc font-body">
            Beyond the screen, I'm a guitarist exploring the geometry of the fretboard.
            This hobby — which I call my 'Fret Atlas' — mirrors my technical work: it's
            about understanding a complex system to create something beautiful and harmonious.
          </p>
          <a href="/projects" class="about-hobby-link">
            See the influence <span class="material-symbols-outlined">arrow_forward</span>
          </a>
        </div>
        <div class="about-hobby-circle"></div>
      </div>

      <!-- Tech Stack (spans 2) -->
      <div class="about-card about-card-stack">
        <h4 class="about-card-title font-headline">Tech Stack</h4>
        <ul class="stack-list">
          <li class="stack-item">
            <span class="stack-dot"></span>
            <span>React &amp; Next.js</span>
          </li>
          <li class="stack-item">
            <span class="stack-dot"></span>
            <span>TypeScript</span>
          </li>
          <li class="stack-item">
            <span class="stack-dot"></span>
            <span>CSS &amp; Design Systems</span>
          </li>
          <li class="stack-item">
            <span class="stack-dot"></span>
            <span>Figma Architecture</span>
          </li>
        </ul>
      </div>

      <!-- Philosophy Quote (spans 4) -->
      <div class="about-card about-card-quote">
        <p class="about-quote font-headline">
          "Design is not just what it looks like and feels like. Design is how it
          works. But for the curator, design is also about what you choose to leave out."
        </p>
        <div class="about-quote-attribution">
          <div class="about-quote-line"></div>
          <span class="about-quote-label font-label">Design Philosophy</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding-block: var(--space-24);
    background-color: var(--color-surface);
  }

  /* Hero */
  .about-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    margin-bottom: var(--space-32);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .about-hero {
      grid-template-columns: 7fr 5fr;
    }
  }

  .about-hero-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .about-title {
    font-size: clamp(2.5rem, 5vw, var(--text-display-lg));
    font-weight: 800;
    letter-spacing: var(--tracking-tighter);
    color: var(--color-on-surface);
    line-height: var(--leading-tight);
  }

  .about-title-accent {
    background: linear-gradient(to right, var(--color-primary), var(--color-primary-container));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
  }

  .about-desc {
    font-size: var(--text-title-md);
    color: var(--color-on-surface-variant);
    line-height: var(--leading-relaxed);
    max-width: 40rem;
  }

  .about-hero-portrait {
    aspect-ratio: 1;
    border-radius: var(--radius-xl);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
    transform: rotate(3deg);
    transition: transform var(--duration-slow) var(--ease-default);
  }

  .about-hero-portrait:hover {
    transform: rotate(0deg);
  }

  .about-hero-portrait img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    transition: filter var(--duration-slower) var(--ease-default);
  }

  .about-hero-portrait:hover img {
    filter: grayscale(0%);
  }

  /* Bento grid — 6 columns on desktop */
  .about-bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .about-bento {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .about-card {
    border-radius: var(--radius-xl);
    padding: var(--space-10);
    display: flex;
    flex-direction: column;
  }

  .about-card-icon {
    font-size: 2.5rem;
    color: var(--color-primary);
    display: block;
    margin-bottom: var(--space-6);
  }

  .about-card-title {
    font-size: var(--text-headline-md);
    font-weight: 700;
    margin-bottom: var(--space-4);
  }

  .about-card-desc {
    font-size: var(--text-body-md);
    color: var(--color-on-surface-variant);
    line-height: var(--leading-relaxed);
  }

  /* Workflow card */
  .about-card-workflow {
    background-color: var(--color-surface-container-low);
    justify-content: space-between;
  }

  @media (min-width: 768px) {
    .about-card-workflow {
      grid-column: span 3;
    }
  }

  .workflow-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    margin-top: var(--space-8);
  }

  .workflow-tag {
    padding: var(--space-1) var(--space-3);
    background-color: var(--color-surface-container);
    color: var(--color-on-surface-variant);
    font-size: var(--text-label-md);
    font-weight: 700;
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: var(--tracking-tight);
  }

  /* Hobby card (primary bg) */
  .about-card-hobby {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .about-card-hobby {
      grid-column: span 3;
    }
  }

  .about-card-hobby-inner {
    position: relative;
    z-index: 1;
  }

  .about-hobby-icon {
    font-size: 2.5rem;
    color: var(--color-primary-container);
    display: block;
    margin-bottom: var(--space-6);
  }

  .about-hobby-title {
    color: var(--color-on-primary);
  }

  .about-hobby-desc {
    color: rgba(192, 255, 243, 0.8);
    margin-bottom: var(--space-6);
  }

  .about-hobby-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 700;
    color: var(--color-primary-container);
    transition: text-decoration var(--duration-normal) var(--ease-default);
  }

  .about-hobby-link:hover {
    text-decoration: underline;
    text-underline-offset: 4px;
  }

  .about-hobby-link .material-symbols-outlined {
    font-size: 1.25rem;
  }

  .about-hobby-circle {
    position: absolute;
    top: -5rem;
    right: -5rem;
    width: 16rem;
    height: 16rem;
    background-color: var(--color-primary-container);
    opacity: 0.1;
    border-radius: var(--radius-full);
    transition: transform var(--duration-slower) var(--ease-default);
  }

  .about-card-hobby:hover .about-hobby-circle {
    transform: scale(1.1);
  }

  /* Tech Stack card */
  .about-card-stack {
    background-color: var(--color-surface-container-highest);
  }

  @media (min-width: 768px) {
    .about-card-stack {
      grid-column: span 2;
    }
  }

  .about-card-stack .about-card-title {
    font-size: var(--text-title-lg);
  }

  .stack-list {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .stack-item {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    font-size: var(--text-body-md);
    font-weight: 500;
    color: var(--color-on-surface);
  }

  .stack-dot {
    width: 0.5rem;
    height: 0.5rem;
    border-radius: var(--radius-full);
    background-color: var(--color-primary);
    flex-shrink: 0;
  }

  /* Philosophy Quote card */
  .about-card-quote {
    background-color: var(--color-surface-bright);
    border: 1px solid rgba(171, 173, 175, 0.1);
    padding: var(--space-12);
    justify-content: space-between;
  }

  @media (min-width: 768px) {
    .about-card-quote {
      grid-column: span 4;
    }
  }

  .about-quote {
    font-size: var(--text-headline-sm);
    font-weight: 300;
    font-style: italic;
    color: rgba(44, 47, 49, 0.8);
    line-height: var(--leading-relaxed);
  }

  .about-quote-attribution {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .about-quote-line {
    width: 3rem;
    height: 1px;
    background-color: var(--color-outline-variant);
  }

  .about-quote-label {
    font-size: var(--text-body-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: var(--color-outline);
  }
</style>
