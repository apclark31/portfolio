---
/* About section */
---

<section class="about" id="about">
  <div class="container">
    <!-- About Hero -->
    <div class="about-hero">
      <div class="about-hero-text">
        <span class="section-label">About</span>
        <h1 class="about-title font-headline">
          Making digital commerce <span class="about-title-accent">work better.</span>
        </h1>
        <p class="about-desc font-body">
          I've built eCommerce operations from the ground up, optimized
          conversion funnels at scale, managed the analytics, and led the
          teams. Every initiative ties back to something measurable.
        </p>
      </div>
    </div>

    <!-- About Bento (6-col grid) -->
    <div class="about-bento">
      <!-- How I Work (spans 3) -->
      <div class="about-card about-card-workflow">
        <div>
          <span class="material-symbols-outlined about-card-icon">architecture</span>
          <h3 class="about-card-title font-headline">How I Work</h3>
          <p class="about-card-desc font-body">
            I start with the data, scope the opportunity, and build a hypothesis.
            Sometimes that means shipping a test. Sometimes the data is clear
            enough to just execute. Every initiative ties back to a metric
            that matters: revenue, conversion rate, or efficiency.
          </p>
        </div>
        <div class="workflow-footer">
          <div class="workflow-tags">
            <span class="workflow-tag">Data-Driven</span>
            <span class="workflow-tag">Ship Fast</span>
            <span class="workflow-tag">Iterate</span>
          </div>
          <a href="/experience" class="workflow-link">
            See my experience <span class="material-symbols-outlined">arrow_forward</span>
          </a>
        </div>
      </div>

      <!-- Results card (spans 3) -->
      <div class="about-card about-card-results">
        <div class="about-card-results-inner">
          <span class="material-symbols-outlined about-results-icon">trending_up</span>
          <h3 class="about-card-title font-headline about-results-title">Proven Results</h3>
          <div class="results-stats">
            <div class="results-stat">
              <span class="results-stat-number font-headline">Millions</span>
              <span class="results-stat-label">In Incremental Growth</span>
            </div>
            <div class="results-stat">
              <span class="results-stat-number font-headline">YoY</span>
              <span class="results-stat-label">DTC Sales Increases</span>
            </div>
            <div class="results-stat">
              <span class="results-stat-number font-headline">Full-Stack</span>
              <span class="results-stat-label">Analytics Recovery &amp; Infrastructure</span>
            </div>
          </div>
          <a href="/projects" class="about-results-link">
            See the work <span class="material-symbols-outlined">arrow_forward</span>
          </a>
        </div>
        <div class="about-results-circle"></div>
      </div>

      <!-- Approach quote card (spans 6) -->
      <div class="about-card about-card-quote">
        <p class="about-quote font-headline">
          "Data isn't just numbers and behavioral analytics. It's empathy
          at scale. When you lead with understanding what your users are
          going through, the right optimization becomes obvious."
        </p>
        <div class="about-quote-attribution">
          <div class="about-quote-line"></div>
          <span class="about-quote-label font-label">Philosophy</span>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    padding-block: var(--space-16);
    background-color: var(--color-surface);
  }

  /* Hero */
  .about-hero {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    margin-bottom: var(--space-16);
    align-items: center;
  }

  .about-hero-text {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .about-title {
    font-size: clamp(2.5rem, 5vw, var(--text-display-lg));
    font-weight: 800;
    letter-spacing: var(--tracking-tighter);
    color: var(--color-on-surface);
    line-height: var(--leading-tight);
  }

  .about-title-accent {
    background: linear-gradient(to right, var(--color-primary), var(--color-primary-container));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    font-style: italic;
  }

  .about-desc {
    font-size: var(--text-title-md);
    color: var(--color-on-surface-variant);
    line-height: var(--leading-relaxed);
    max-width: 40rem;
  }

  /* Bento grid */
  .about-bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 768px) {
    .about-bento {
      grid-template-columns: repeat(6, 1fr);
    }
  }

  .about-card {
    border-radius: var(--radius-xl);
    padding: var(--space-10);
    display: flex;
    flex-direction: column;
  }

  .about-card-icon {
    font-size: 2.5rem;
    color: var(--color-primary);
    display: block;
    margin-bottom: var(--space-6);
  }

  .about-card-title {
    font-size: var(--text-headline-md);
    font-weight: 700;
    margin-bottom: var(--space-4);
  }

  .about-card-desc {
    font-size: var(--text-body-md);
    color: var(--color-on-surface-variant);
    line-height: var(--leading-relaxed);
  }

  /* Workflow card */
  .about-card-workflow {
    background-color: var(--color-surface-container-low);
    justify-content: space-between;
  }

  @media (min-width: 768px) {
    .about-card-workflow {
      grid-column: span 3;
    }
  }

  .workflow-footer {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    margin-top: var(--space-8);
  }

  .workflow-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
  }

  .workflow-tag {
    padding: var(--space-1) var(--space-3);
    background-color: var(--color-surface-container);
    color: var(--color-on-surface-variant);
    font-size: var(--text-label-md);
    font-weight: 700;
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: var(--tracking-tight);
  }

  .workflow-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 700;
    font-size: var(--text-body-sm);
    color: var(--color-primary);
    text-decoration: none;
    transition: gap var(--duration-normal) var(--ease-default);
  }

  .workflow-link:hover {
    gap: var(--space-3);
  }

  .workflow-link .material-symbols-outlined {
    font-size: 1rem;
  }

  /* Results card (primary bg) */
  .about-card-results {
    background-color: var(--color-primary);
    color: var(--color-on-primary);
    position: relative;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .about-card-results {
      grid-column: span 3;
    }
  }

  .about-card-results-inner {
    position: relative;
    z-index: 1;
  }

  .about-results-icon {
    font-size: 2.5rem;
    color: #fff;
    display: block;
    margin-bottom: var(--space-6);
  }

  .about-results-title {
    color: var(--color-on-primary);
  }

  .results-stats {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    margin-bottom: var(--space-6);
  }

  .results-stat {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .results-stat-number {
    font-size: var(--text-headline-lg);
    font-weight: 800;
    color: #fff;
  }

  .results-stat-label {
    font-size: var(--text-body-sm);
    color: rgba(255, 255, 255, 0.75);
    font-weight: 500;
  }

  .about-results-link {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-weight: 700;
    color: #fff;
    text-decoration: none;
    transition: gap var(--duration-normal) var(--ease-default);
  }

  .about-results-link:hover {
    gap: var(--space-3);
  }

  .about-results-link .material-symbols-outlined {
    font-size: 1.25rem;
  }

  .about-results-circle {
    position: absolute;
    top: -5rem;
    right: -5rem;
    width: 16rem;
    height: 16rem;
    background-color: var(--color-primary-container);
    opacity: 0.1;
    border-radius: var(--radius-full);
    transition: transform var(--duration-slower) var(--ease-default);
  }

  .about-card-results:hover .about-results-circle {
    transform: scale(1.1);
  }

  /* Approach quote card */
  .about-card-quote {
    background-color: var(--color-surface-bright);
    border: 1px solid rgba(171, 173, 175, 0.1);
    padding: var(--space-12);
    justify-content: space-between;
  }

  @media (min-width: 768px) {
    .about-card-quote {
      grid-column: span 6;
    }
  }

  .about-quote {
    font-size: var(--text-headline-sm);
    font-weight: 300;
    font-style: italic;
    color: rgba(44, 47, 49, 0.8);
    line-height: var(--leading-relaxed);
  }

  .about-quote-attribution {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-top: var(--space-8);
  }

  .about-quote-line {
    width: 3rem;
    height: 1px;
    background-color: var(--color-outline-variant);
  }

  .about-quote-label {
    font-size: var(--text-body-sm);
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: var(--color-outline);
  }
</style>
