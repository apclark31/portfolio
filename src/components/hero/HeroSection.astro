---
import GradientButton from '../shared/GradientButton.astro';
import SecondaryButton from '../shared/SecondaryButton.astro';
---

<section class="hero">
  <div class="hero-inner container">
    <div class="hero-content">
      <div class="hero-badge">Now Available for New Projects</div>

      <h1 class="hero-title font-headline">
        Crafting <span class="hero-accent">Measurable</span><br />Experiences.
      </h1>

      <p class="hero-description font-body">
        I am a Design-Driven Developer &amp; CRO Specialist dedicated to
        bridging the gap between aesthetic excellence and high-performance
        metrics. Whether it's a corporate ecosystem or an experimental hobby
        project, I curate every pixel with intent.
      </p>

      <div class="hero-actions">
        <GradientButton href="/experience" icon="arrow_forward">
          Explore My Experience
        </GradientButton>
        <SecondaryButton href="/projects">
          Check Out My Hobbies
        </SecondaryButton>
      </div>
    </div>

    <div class="hero-portrait-wrap">
      <div class="hero-portrait">
        <img
          src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&h=750&fit=crop&crop=face"
          alt="Alex Clark — Professional Portrait"
          class="hero-portrait-img"
          loading="eager"
        />
      </div>

      <!-- Floating stat card -->
      <div class="hero-stat-card ghost-border">
        <div class="hero-stat-indicator">
          <span class="hero-stat-dot"></span>
          <span class="hero-stat-label font-label">Live Stats</span>
        </div>
        <p class="hero-stat-text font-body">
          98% User Satisfaction across all 2024 launches.
        </p>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: calc(var(--nav-height) + var(--space-12));
    padding-bottom: var(--space-20);
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-inner {
      grid-template-columns: 7fr 5fr;
    }
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .hero-badge {
    display: inline-block;
    align-self: flex-start;
    padding: var(--space-1) var(--space-4);
    border-radius: var(--radius-full);
    background-color: var(--color-surface-container-high);
    color: var(--color-primary);
    font-family: var(--font-label);
    font-size: var(--text-label-md);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, var(--text-display-lg));
    font-weight: 800;
    letter-spacing: var(--tracking-tighter);
    line-height: var(--leading-tight);
    color: var(--color-on-surface);
  }

  .hero-accent {
    color: var(--color-primary);
    font-style: italic;
  }

  .hero-description {
    font-size: var(--text-body-lg);
    color: var(--color-on-surface-variant);
    line-height: var(--leading-relaxed);
    max-width: 36rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding-top: var(--space-4);
  }

  .hero-portrait-wrap {
    position: relative;
  }

  .hero-portrait {
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-4xl);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
    background-color: var(--color-surface-container-low);
  }

  .hero-portrait-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    transform: scale(1.05);
    transition: filter var(--duration-slower) var(--ease-default),
                transform var(--duration-slower) var(--ease-default);
  }

  .hero-portrait:hover .hero-portrait-img {
    filter: grayscale(0%);
    transform: scale(1);
  }

  .hero-stat-card {
    position: absolute;
    bottom: calc(-1 * var(--space-6));
    left: calc(-1 * var(--space-6));
    background-color: var(--color-surface-container-lowest);
    padding: var(--space-6);
    border-radius: var(--radius-2xl);
    box-shadow: var(--shadow-xl);
    max-width: 200px;
  }

  .hero-stat-indicator {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-2);
  }

  .hero-stat-dot {
    width: 0.75rem;
    height: 0.75rem;
    border-radius: var(--radius-full);
    background-color: var(--color-primary);
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.5; }
  }

  .hero-stat-label {
    font-size: 10px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: var(--color-on-surface-variant);
  }

  .hero-stat-text {
    font-size: var(--text-body-sm);
    font-weight: 500;
    color: var(--color-on-surface);
  }

  @media (max-width: 1023px) {
    .hero-stat-card {
      bottom: calc(-1 * var(--space-4));
      left: var(--space-2);
    }
  }
</style>
