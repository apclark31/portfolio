---
import GradientButton from '../shared/GradientButton.astro';
import SecondaryButton from '../shared/SecondaryButton.astro';
---

<section class="hero">
  <div class="hero-inner container">
    <div class="hero-content">
      <p class="hero-label font-label">eCommerce Leader &amp; CRO / Analytics Expert</p>

      <h1 class="hero-title font-headline">
        Alex Clark
        <svg class="hero-pnw" viewBox="0 0 60 80" fill="currentColor" aria-hidden="true">
          <path d="M30 0 L24 12 L28 12 L18 28 L24 28 L12 46 L20 46 L6 66 L22 66 L22 80 L38 80 L38 66 L54 66 L40 46 L48 46 L36 28 L42 28 L32 12 L36 12 Z"/>
        </svg>
      </h1>

      <p class="hero-description font-body">
        Hi, I'm Alex. Over the past 12 years, I've worked with global brands
        to drive eCommerce growth through conversion optimization, analytics,
        and digital strategy. From hands-on implementation to leading the
        strategy, I've driven growth at every stage of the eCommerce journey.
      </p>

      <div class="hero-disciplines">
        <span class="hero-discipline">CRO &amp; A/B Testing</span>
        <span class="hero-discipline">Content &amp; On-Site Marketing</span>
        <span class="hero-discipline">eCommerce Operations</span>
        <span class="hero-discipline">Analytics &amp; Data</span>
        <span class="hero-discipline">UI/UX</span>
        <span class="hero-discipline">Merchandising</span>
      </div>

      <div class="hero-actions">
        <GradientButton href="/experience" icon="arrow_forward">
          View Experience
        </GradientButton>
        <SecondaryButton href="/projects">
          Projects &amp; Tools
        </SecondaryButton>
      </div>
    </div>

    <div class="hero-portrait-wrap">
      <div class="hero-portrait">
        <img
          src="/images/alex-headshot.jpg"
          alt="Alex Clark"
          class="hero-portrait-img"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: calc(var(--nav-height) + var(--space-12));
    padding-bottom: var(--space-20);
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-8);
    align-items: center;
  }

  /* Mobile: portrait first, then content */
  .hero-portrait-wrap {
    order: -1;
    max-width: 280px;
    margin-inline: auto;
  }

  @media (min-width: 1024px) {
    .hero-inner {
      grid-template-columns: 7fr 5fr;
      gap: var(--space-12);
    }

    .hero-portrait-wrap {
      order: 0;
      max-width: none;
      margin-inline: 0;
    }
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
    text-align: center;
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-content {
      text-align: left;
      align-items: flex-start;
    }
  }

  .hero-label {
    font-size: var(--text-label-md);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: var(--color-primary);
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 800;
    letter-spacing: var(--tracking-tighter);
    line-height: var(--leading-tight);
    color: var(--color-on-surface);
  }

  .hero-pnw {
    display: inline-block;
    width: 0.55em;
    height: 0.65em;
    color: var(--color-primary);
    vertical-align: baseline;
  }

  .hero-description {
    font-size: var(--text-body-lg);
    color: var(--color-on-surface-variant);
    line-height: var(--leading-relaxed);
    max-width: 36rem;
  }

  .hero-disciplines {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding-top: var(--space-2);
    justify-content: center;
  }

  @media (min-width: 1024px) {
    .hero-disciplines {
      justify-content: flex-start;
    }
  }

  .hero-discipline {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-lg);
    background-color: var(--color-surface-container);
    color: var(--color-on-surface-variant);
    font-family: var(--font-label);
    font-size: var(--text-label-md);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3);
    padding-top: var(--space-4);
    justify-content: center;
  }

  @media (min-width: 1024px) {
    .hero-actions {
      justify-content: flex-start;
    }
  }

  .hero-portrait {
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-4xl);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
    background-color: var(--color-surface-container-low);
  }

  .hero-portrait-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
</style>
