---
import GradientButton from '../shared/GradientButton.astro';
import SecondaryButton from '../shared/SecondaryButton.astro';
---

<section class="hero">
  <div class="hero-inner container">
    <div class="hero-content">
      <p class="hero-label font-label">eCommerce Leader &amp; CRO Specialist</p>

      <h1 class="hero-title font-headline">
        Alex Clark
      </h1>

      <p class="hero-description font-body">
        12+ years driving growth across eCommerce, conversion optimization,
        front-end engineering, operations, analytics, and customer experience.
        From building the tech to leading the strategy &mdash; I've done both.
      </p>

      <div class="hero-disciplines">
        <span class="hero-discipline">CRO &amp; A/B Testing</span>
        <span class="hero-discipline">Front-End Engineering</span>
        <span class="hero-discipline">eCommerce Operations</span>
        <span class="hero-discipline">Analytics &amp; Data</span>
        <span class="hero-discipline">UI/UX</span>
        <span class="hero-discipline">Merchandising</span>
      </div>

      <div class="hero-actions">
        <GradientButton href="/experience" icon="arrow_forward">
          View Experience
        </GradientButton>
        <SecondaryButton href="/projects">
          Projects &amp; Tools
        </SecondaryButton>
      </div>
    </div>

    <div class="hero-portrait-wrap">
      <div class="hero-portrait">
        <img
          src="https://images.unsplash.com/photo-1507003211169-0a1dd7228f2d?w=600&h=750&fit=crop&crop=face"
          alt="Alex Clark"
          class="hero-portrait-img"
          loading="eager"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    padding-top: calc(var(--nav-height) + var(--space-12));
    padding-bottom: var(--space-20);
    min-height: 100vh;
    display: flex;
    align-items: center;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-12);
    align-items: center;
  }

  @media (min-width: 1024px) {
    .hero-inner {
      grid-template-columns: 7fr 5fr;
    }
  }

  .hero-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .hero-label {
    font-size: var(--text-label-md);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-widest);
    color: var(--color-primary);
  }

  .hero-title {
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 800;
    letter-spacing: var(--tracking-tighter);
    line-height: var(--leading-tight);
    color: var(--color-on-surface);
  }

  .hero-description {
    font-size: var(--text-body-lg);
    color: var(--color-on-surface-variant);
    line-height: var(--leading-relaxed);
    max-width: 36rem;
  }

  .hero-disciplines {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding-top: var(--space-2);
  }

  .hero-discipline {
    display: inline-block;
    padding: var(--space-1) var(--space-3);
    border-radius: var(--radius-lg);
    background-color: var(--color-surface-container);
    color: var(--color-on-surface-variant);
    font-family: var(--font-label);
    font-size: var(--text-label-md);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-4);
    padding-top: var(--space-4);
  }

  .hero-portrait-wrap {
    position: relative;
  }

  .hero-portrait {
    aspect-ratio: 4 / 5;
    border-radius: var(--radius-4xl);
    overflow: hidden;
    box-shadow: var(--shadow-xl);
    background-color: var(--color-surface-container-low);
  }

  .hero-portrait-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    transform: scale(1.05);
    transition: filter var(--duration-slower) var(--ease-default),
                transform var(--duration-slower) var(--ease-default);
  }

  .hero-portrait:hover .hero-portrait-img {
    filter: grayscale(0%);
    transform: scale(1);
  }
</style>
