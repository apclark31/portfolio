---
interface Interest {
  icon: string;
  title: string;
  description: string;
}

interface Props {
  interests: Interest[];
}

const { interests } = Astro.props;
---

<section class="interests">
  <div class="container">
    <div class="interests-header">
      <h2 class="interests-title font-headline">Personal Interests</h2>
      <div class="interests-divider"></div>
    </div>

    <div class="interests-grid">
      {interests.map((item) => (
        <div class="interest-card">
          <div class="interest-icon-wrap">
            <span class="material-symbols-outlined interest-icon">{item.icon}</span>
          </div>
          <h4 class="interest-card-title font-headline">{item.title}</h4>
          <p class="interest-card-desc font-body">{item.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .interests {
    padding-block: var(--space-24);
    background-color: var(--color-surface);
  }

  .interests-header {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    margin-bottom: var(--space-12);
  }

  .interests-title {
    font-size: var(--text-headline-md);
    font-weight: 700;
    letter-spacing: var(--tracking-tight);
    color: var(--color-on-surface);
    white-space: nowrap;
  }

  .interests-divider {
    height: 1px;
    flex-grow: 1;
    background-color: rgba(171, 173, 175, 0.2);
  }

  .interests-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-6);
  }

  @media (min-width: 1024px) {
    .interests-grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .interest-card {
    padding: var(--space-8);
    background-color: var(--color-surface-container-low);
    border-radius: var(--radius-2xl);
    border: 1px solid transparent;
    transition: background-color var(--duration-normal) var(--ease-default),
                box-shadow var(--duration-normal) var(--ease-default);
  }

  .interest-card:hover {
    background-color: var(--color-surface-container-lowest);
    box-shadow: 0 12px 40px rgba(0, 103, 93, 0.05);
  }

  .interest-icon-wrap {
    width: 3rem;
    height: 3rem;
    border-radius: var(--radius-xl);
    background-color: rgba(106, 242, 222, 0.3);
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-6);
  }

  .interest-icon {
    color: var(--color-primary);
    font-size: 1.5rem;
  }

  .interest-card-title {
    font-size: var(--text-body-md);
    font-weight: 700;
    color: var(--color-on-surface);
    margin-bottom: var(--space-2);
  }

  .interest-card-desc {
    font-size: var(--text-body-sm);
    color: var(--color-on-surface-variant);
    line-height: var(--leading-relaxed);
  }
</style>
